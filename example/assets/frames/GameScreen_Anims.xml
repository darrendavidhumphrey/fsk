    <!--  other animation tags tween="LINEAR" easing="EASE_IN" notifyMask="OnComplete" -->
 
    	<animationGroup name="RevealAnswer">
    		<animation type="RotateX" target="_questions[answer]._root" startVal="0" endVal="180" duration="$clueRevealTime"/>
    		<animation type="Visibility" target="_questions[answer]._front" endVal="false" duration="$clueRevealTime/2.0"/>
    	    <animation type="Visibility" target="_questions[answer]._back" endVal="true" duration="$clueRevealTime/2.0"/>
    	    <animation type="TextVal" target="roundScoreText" val="theScore"/>
    	    <animation type="Sound" val="Ding"/>
    	</animationGroup>
    	
    		<animation name="fadeInLogo" target="logo.alpha" start="0.0" end="1.0" duration="$fadeTime"/>
    		<animation name="fadeOutLogo" target="logo.alpha" start="1.0" end="0.0"  duration="$fadeTime"/>
    		
